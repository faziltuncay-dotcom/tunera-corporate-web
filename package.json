{
  "name": "tunera-corporate-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "next build",
    "start": "next start -p 3010",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test --test-reporter=spec tests",
    "promo:capture": "pnpm --dir tools/promo-video --ignore-workspace run capture",
    "promo:render": "pnpm --dir tools/promo-video --ignore-workspace run render",
    "promo:video": "pnpm promo:capture && pnpm promo:render"
  },
  "dependencies": {
    "next": "14.2.35",
    "postgres": "3.4.4",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "8.4.39",
    "prettier": "3.3.3",
    "tailwindcss": "3.4.7",
    "typescript": "5.5.4"
  }
}
